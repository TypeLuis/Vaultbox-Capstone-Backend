# ENTER PORT NUMBER (Default 3040)
PORT=3040

# Enter a secret only you know
JWTSECRET=

MONGODB_PORT:=27017

# ENTER MONGODB URL
MONGODB_URI=mongodb://localhost:27017/vaultbox


# Your IP Address
MINIO_ENDPOINT=localhost

# Minio PORT Number (Default 9000)
MINIO_PORT=9000

# SSL
MINIO_USE_SSL=false

# Minio Username (can be changed any time)
MINIO_ACCESS_KEY=minioadmin

# Minio Password (can be changed any time)
MINIO_SECRET_KEY=minioadmin

# Minio container name
MINIO_BUCKET=vaultbox

# Minio Region
MINIO_REGION=us-east-1

# Directory where you want to keep Minio files in server (Optional)
DIRECTORY=

# True if not deployed
SELF_HOSTED=true