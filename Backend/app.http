# @baseUrl = http://localhost:3040
@baseUrl = http://192.168.8.166:3040

# -------------------------
# 1) REGISTER (returns token)
# -------------------------

# @name register
POST {{baseUrl}}/api/users
Content-Type: application/json

{
  "name": "Test User3",
  "email": "test3@example.com",
  "password": "password123"
}

###
# Token from register response (VSCode REST Client)
# @token = {{register.response.body.token}}

# -------------------------
# 2) LOGIN (optional, also returns token)
# -------------------------

###
# @name login
POST {{baseUrl}}/api/auth
Content-Type: application/json

{
  "email": "test2@example.com",
  "password": "password123"
}

# @token = {{login.response.body.token}}

###
# If you prefer login token instead of register token, swap:
# @token = {{login.response.body.token}}

# -------------------------
# 3) WHO AM I (requires token)
# -------------------------

# @name me
GET {{baseUrl}}/api/auth
x-auth-token:  eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VyIjp7ImlkIjoiNjlhNjBlNTNiMTA0NDI5MDUzYzZkNDRjIn0sImlhdCI6MTc3MjUxMTgyOSwiZXhwIjoxNzcyNTIyNjI5fQ.5h80fH51V_KLpYXRQfKtTAnPkfITZWFgwQ4V4cbMeOc

###
@userId = {{me.response.body._id}}

# =========================
# DEVICES
# =========================

# -------------------------
# Create Device (manual mode)
# Your device route expects body.userId and body.q
# -------------------------

# @name createDevice
POST {{baseUrl}}/api/device?q=no
Content-Type: application/json

{
  "userId": "{{userId}}",
  "name": "VaultBox Main",
  "drives": [
    {
      "fs": "/dev/sda1",
      "type": "ext4",
      "mount": "/",
      "sizeMB": 500000,
      "usedMB": 200000,
      "availableMB": 300000,
      "usePercent": 40,
      "rw": true
    }
  ]
}

###


# @name createDevice
POST {{baseUrl}}/api/device?q=yes
Content-Type: application/json

{
  "userId": "{{userId}}"
}

###
@deviceId = {{createDevice.response.body._id}}

# -------------------------
# Get Devices (filter by userId)
# NOTE: your deviceRoutes has a small bug using filter.deviceId instead of filter.userId.
# If it returns empty, that’s why.
# -------------------------
GET {{baseUrl}}/api/device?userId={{userId}}

###
# Update Device
PUT {{baseUrl}}/api/device/{{deviceId}}
Content-Type: application/json

{
  "name": "VaultBox Updated"
}

###
# Delete Device
DELETE {{baseUrl}}/api/device/{{deviceId}}

# =========================
# APPS
# =========================

###
# @name createApp
POST {{baseUrl}}/api/app
Content-Type: application/json

{
  "userId": "{{userId}}",
  "deviceId": "{{deviceId}}",
  "slug": "jellyfin",
  "name": "Jellyfin",
  "port": 8096,
  "description": "Media server"
}

###
@appId = {{createApp.response.body._id}}

###
# List Apps for device
GET {{baseUrl}}/api/app?userId={{userId}}&deviceId={{deviceId}}

###
# Update App (status etc.)
PATCH {{baseUrl}}/api/app/{{appId}}
Content-Type: application/json

{
  "userId": "{{userId}}",
  "status": "running"
}

###
# Delete App
DELETE {{baseUrl}}/api/app/{{appId}}?userId={{userId}}


###
# =========================
# FILES (MinIO-backed)
# IMPORTANT:
# Your fileRoutes currently accept userId from:
# - req.user.id (ONLY if you add auth middleware to /api/file)
# - OR query/body userId (current fallback)
# So we pass userId in query for now.
# =========================

# @name uploadFile
POST {{baseUrl}}/api/file/upload?deviceId={{deviceId}}&userId={{userId}}
Content-Type: multipart/form-data; boundary=MyBoundary

--MyBoundary
Content-Disposition: form-data; name="file"; filename="test.txt"
Content-Type: text/plain

Hello from VaultBox!
--MyBoundary--

###
@fileId = {{uploadFile.response.body._id}}

###
# List Files
GET {{baseUrl}}/api/file?deviceId={{deviceId}}&userId={{userId}}

###
# Download File
GET {{baseUrl}}/api/file/{{fileId}}/download?userId={{userId}}

###
# Delete File
DELETE {{baseUrl}}/api/file/{{fileId}}?userId={{userId}}